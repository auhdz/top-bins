# Site URL for metadata, Open Graph, and Stripe Checkout success/cancel redirects.
# Use your real domain in production, e.g. https://your-project.vercel.app
# Variable name is NEXT_PUBLIC_SITE_URL (letter N E X T, not EXT).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL — required for persisting subscriptions + webhook idempotency in production
DATABASE_URL=

# --- Stripe (subscriptions: weekly bin rentals) ---
# Dashboard: https://dashboard.stripe.com/apikeys — never commit real secrets.
# If a secret was ever exposed, rotate it in the Dashboard and update this file locally.

# Required: server secret (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=

# Webhook signing secret from Dashboard → Developers → Webhooks, or from `stripe listen`
STRIPE_WEBHOOK_SECRET=

# Browser (optional): @stripe/stripe-js / Elements
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: recurring weekly Price IDs from Dashboard (preferred for reporting)
# STRIPE_PRICE_STANDARD_WEEKLY=price_...
# STRIPE_PRICE_LARGE_WEEKLY=price_...

# Optional: Product IDs when using price_data (subscriptions line items link to prod_*)
STRIPE_PRODUCT_STANDARD_ID=prod_UKEzSkYiPUqf3E
STRIPE_PRODUCT_LARGE_ID=prod_UKFCr1uTlk4IRG

# Optional: override default “Rent Now” links to an external URL instead of /rental
# NEXT_PUBLIC_PAY_NOW_URL=

# --- Transactional email (Resend) — optional; omit to skip sending ---
# https://resend.com — verify a domain or use onboarding@resend.dev for tests only
RESEND_API_KEY=
# Example: "Bear Box Rentals <onboarding@resend.dev>"
EMAIL_FROM=
# Internal copy of new subscriptions (defaults to site email if unset)
# EMAIL_ORDER_NOTIFY_TO=
