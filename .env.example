# --- Required for production Stripe + webhooks + DB ---
# Copy to .env.local and fill in. Never commit real values.

# Public site URL (no trailing slash). Used for Stripe success/cancel redirects and SEO.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL connection string (webhooks + subscription rows need this in production).
DATABASE_URL=

# Stripe API secret: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Webhook signing secret: Dashboard → Developers → Webhooks (endpoint URL below), or `stripe listen` CLI.
STRIPE_WEBHOOK_SECRET=
